    "_postman_id": "503e5489-c4a4-4a3e-b8f7-f177a6b074e0",
    "name": "FiscalNote Organization API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The FiscalNote Organization API provides access to FiscalNote's data on government organizations in the United States and globally. It covers legislative committees, federal agencies, and other governmental bodies. Developers can use this API to retrieve structured information about government organizations, enabling integration of organizational data into policy tracking, compliance, and government relations applications.\n\nContact Support:\n Name: FiscalNote Support",
      "type": "text/plain"
    }
  }
